import cv2
from yolov5 import load
import argparse
import os

# 引数
parser = argparse.ArgumentParser()
parser.add_argument("num")
args = parser.parse_args()

num = args.num.zfill(4)

# パス
base_dir = "/mnt/c/home/40_photo/2026-01-03"
input_path = os.path.join(base_dir, f"DSC0{num}.JPG")
output_path = os.path.join(base_dir, f"output_{num}.jpg")

# モデル
model = load("best.pt")

# 画像
img = cv2.imread(input_path)
if img is None:
    raise ValueError(f"Image not found: {input_path}")

# 推論
results = model(img)

# ブラー
for *box, conf, cls in results.xyxy[0]:
    x1, y1, x2, y2 = map(int, box)

    roi = img[y1:y2, x1:x2]
    if roi.size == 0:
        continue

    img[y1:y2, x1:x2] = cv2.GaussianBlur(roi, (31, 31), 0)

# 保存
cv2.imwrite(output_path, img)
print(f"Saved: {output_path}")
